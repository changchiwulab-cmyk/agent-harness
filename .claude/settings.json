{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "Edit(system/**)",
      "Write(system/**)",
      "Edit(skills/**)",
      "Write(skills/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(memory/**)",
      "Write(memory/**)",
      "Edit(outputs/reports/**)",
      "Write(outputs/reports/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/permissions_guard.py\""
          }
        ]
      }
    ]
  }
}
